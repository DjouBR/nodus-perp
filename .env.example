# Base path (leave empty for root)
BASEPATH=

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Gere um secret forte: openssl rand -base64 32
NEXTAUTH_SECRET=seu_secret_super_seguro_aqui
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Obter em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Facebook OAuth ───────────────────────────────────────────────────────────
# Obter em: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/nodus
